# Production environment template.
# Copy values into your hosting provider's secret/env panel. Do not commit real keys.

NODE_ENV=production

# Data store
DATA_STORE_PROVIDER=supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# New Supabase projects may show this as publishable key. Either name is accepted.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# New Supabase projects may show this as secret key. Either name is accepted.
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET_IMPORTS=imports
SUPABASE_PAGE_CACHE_MS=10000

# Supabase Auth. Enable only after at least one Auth user can log in.
APP_AUTH_ENABLED=true

# Background queue. Required for production lead tasks with 100+ companies.
# Use a TCP Redis URL. BullMQ requires Redis commands over a normal Redis connection.
REDIS_URL=redis://localhost:6379
QUEUE_ENABLED=true
QUEUE_NAME_LEAD_GENERATION=lead-generation
WORKER_CONCURRENCY=1
ENRICHMENT_COMPANY_CONCURRENCY=5
# Max 5 for internal beta. Keep this conservative to avoid search-provider rate limits.
PRODUCT_SEARCH_MINIMAX_TOOL_QUERIES=1
# Product search lets the selected content model plan only the first few tool calls,
# then uses direct SearchProviderRouter calls for speed.
PRODUCT_SEARCH_CONTENT_MODEL_TOOL_QUERIES=1

# Production guardrails
SECURITY_RATE_LIMIT_ENABLED=true
SECURITY_RATE_LIMIT_BACKEND=redis
SECURITY_AUDIT_LOG_ENABLED=true
RATE_LIMIT_RUNS_START_PER_MINUTE=5
RATE_LIMIT_IMPORT_ENRICH_PER_MINUTE=12
RATE_LIMIT_BUYER_FIT_PER_MINUTE=12
RATE_LIMIT_EMAIL_DRAFT_PER_MINUTE=10
RATE_LIMIT_EMAIL_SEND_PER_5_MINUTES=3
RATE_LIMIT_COMPANIES_EXPORT_PER_5_MINUTES=10
RATE_LIMIT_REVIEW_ACTION_PER_MINUTE=30
RATE_LIMIT_CRM_WRITE_PER_MINUTE=30
RATE_LIMIT_AUTH_LOGIN_PER_MINUTE=10
RATE_LIMIT_SETTINGS_TEST_PER_MINUTE=20
RATE_LIMIT_SEARCH_PROVIDER_PER_MINUTE=30
RATE_LIMIT_MINIMAX_PER_MINUTE=20

# Content model provider. Use qwen for the Qwen Cloud hackathon build.
CONTENT_MODEL_PROVIDER=qwen

# Qwen Cloud / DashScope draft, scoring, keyword, and tool-planning generation
QWEN_REAL_MODE=true
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
# Aliases accepted by the Qwen provider:
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# MiniMax fallback
MINIMAX_REAL_MODE=true
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3

# Search providers. Configure at least one. The router will not call all providers by default.
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
YOU_API_KEY=
YOU_BASE_URL=https://ydc-index.io

# Email sending. Keep false until sender domain, test inbox, and approved-only rules are verified.
EMAIL_PROVIDER=mock
EMAIL_SEND_REAL_MODE=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_SECURE=true

# Permanently disabled legacy web automation.
CROSS_SEARCH_ENABLED=false
CROSS_SEARCH_REAL_MODE=false
CROSS_SEARCH_USERNAME=
CROSS_SEARCH_PASSWORD=
CROSS_SEARCH_HEADLESS=false
CROSS_SEARCH_PROFILE_DIR=.playwright/cross-search-profile
CROSS_SEARCH_BASE_URL=
CROSS_SEARCH_ONE_SEARCH_URL=

# Optional public email/domain lookup provider
VEMAIL_API_KEY=
VEMAIL_BASE_URL=
