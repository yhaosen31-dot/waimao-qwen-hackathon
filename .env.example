# Provider mode is mock by default in code. Fill these only when wiring real adapters later.

# Data store. Keep local by default; set DATA_STORE_PROVIDER=supabase only after
# running supabase/schema.sql and filling the Supabase variables below.
DATA_STORE_PROVIDER=local
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# New Supabase projects may show this as publishable key. Either name is accepted.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# New Supabase projects may show this as secret key. Either name is accepted.
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET_IMPORTS=imports
SUPABASE_STORE_CACHE_MS=0
SUPABASE_PAGE_CACHE_MS=0
SUPABASE_ALLOW_FULL_STORE_WRITE=false

# Supabase Auth. Keep false locally until you have created a Supabase Auth user.
APP_AUTH_ENABLED=false

# Background queue. Keep disabled unless Redis and the worker are running.
REDIS_URL=redis://localhost:6379
QUEUE_ENABLED=false
QUEUE_NAME_LEAD_GENERATION=lead-generation
WORKER_CONCURRENCY=1
ENRICHMENT_COMPANY_CONCURRENCY=1
# Max 5. Higher values can trigger search-provider rate limits quickly.
PRODUCT_SEARCH_MINIMAX_TOOL_QUERIES=1
# Product search uses MiniMax tool-use only for the first few queries, then direct SearchProviderRouter for speed.

# Production guardrails
SECURITY_RATE_LIMIT_ENABLED=true
SECURITY_RATE_LIMIT_BACKEND=redis
SECURITY_AUDIT_LOG_ENABLED=true
RATE_LIMIT_RUNS_START_PER_MINUTE=5
RATE_LIMIT_IMPORT_ENRICH_PER_MINUTE=12
RATE_LIMIT_BUYER_FIT_PER_MINUTE=12
RATE_LIMIT_EMAIL_DRAFT_PER_MINUTE=10
RATE_LIMIT_EMAIL_SEND_PER_5_MINUTES=3
RATE_LIMIT_COMPANIES_EXPORT_PER_5_MINUTES=10
RATE_LIMIT_REVIEW_ACTION_PER_MINUTE=30
RATE_LIMIT_CRM_WRITE_PER_MINUTE=30
RATE_LIMIT_AUTH_LOGIN_PER_MINUTE=10
RATE_LIMIT_SETTINGS_TEST_PER_MINUTE=20
RATE_LIMIT_SEARCH_PROVIDER_PER_MINUTE=30
RATE_LIMIT_MINIMAX_PER_MINUTE=20

# MiniMax draft/content generation
MINIMAX_API_KEY=
MINIMAX_REAL_MODE=false
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3

# Search enrichment. Leave empty for mock mode; set a key to enable real mode server-side.
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
YOU_API_KEY=
YOU_BASE_URL=https://ydc-index.io

# Resend email provider
EMAIL_PROVIDER=resend
EMAIL_SEND_REAL_MODE=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=

# SMTP email provider
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_SECURE=true

# Cross search connector is disabled by default.
# Do not enable it when account risk control is detected.
CROSS_SEARCH_ENABLED=false
CROSS_SEARCH_REAL_MODE=false
CROSS_SEARCH_USERNAME=
CROSS_SEARCH_PASSWORD=
CROSS_SEARCH_HEADLESS=false
CROSS_SEARCH_PROFILE_DIR=.playwright/cross-search-profile
CROSS_SEARCH_BASE_URL=
CROSS_SEARCH_ONE_SEARCH_URL=

# Foreign trade email lookup by domain
VEMAIL_API_KEY=
VEMAIL_BASE_URL=
