# Alibaba Cloud Function Compute demo environment.
# Keep secrets hidden in the FC environment-variable panel.

NODE_ENV=production

DATA_STORE_PROVIDER=local
LOCAL_DATA_DIR=/tmp/waimao-data
APP_AUTH_ENABLED=false

QUEUE_ENABLED=false
REDIS_URL=

CONTENT_MODEL_PROVIDER=qwen
QWEN_REAL_MODE=false
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
PRODUCT_SEARCH_CONTENT_MODEL_TOOL_QUERIES=1

EMAIL_PROVIDER=mock
EMAIL_SEND_REAL_MODE=false
